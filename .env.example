# Copy to .env and adjust for local (non-Docker) runs. docker-compose sets
# its own values for DATABASE_URL/REDIS_URL/STORAGE_BACKEND/LOCAL_STORAGE_PATH.

DATABASE_URL=postgresql+asyncpg://intelliextract:intelliextract@localhost:5432/intelliextract
REDIS_URL=redis://localhost:6379/0

# "local" or "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=storage
MAX_UPLOAD_SIZE_MB=20

# Only needed when STORAGE_BACKEND=s3
S3_BUCKET_NAME=
AWS_REGION=

# Only needed if tesseract isn't on PATH (common on Windows dev boxes;
# e.g. C:\Program Files\Tesseract-OCR\tesseract.exe). Not needed in Docker.
TESSERACT_CMD=

# Free tier: console.groq.com -> API Keys -> Create Key. Only the worker
# service calls the LLM; docker-compose reads this file to populate it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gates POST /api/v1/auth/keys (sent as X-Admin-Key). Generate your own,
# e.g.: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_API_KEY=
